#!/bin/bash
# sandbox - run a command in a bubblewrap sandbox with network isolation
set -euo pipefail

if ! command -v bwrap &>/dev/null; then
  echo "bwrap not found. Install bubblewrap" >&2
  exit 1
fi

if [ $# -eq 0 ]; then
  echo "Usage: sandbox <command> [args...]" >&2
  exit 1
fi

HOME="${HOME:-$(getent passwd "$USER" | cut -d: -f6)}"
NET_ARG=${NET_ARG:---unshare-net}

FORBIDDEN_DIRS=(
  "${PASSAGE_DIR:-$HOME/.passage}"
  "${HOME}/.ssh"
  "${HOME}/.gnupg"
)

HIDDEN_ARGS=()
for path in "${FORBIDDEN_DIRS[@]}"; do
  [ -d "$path" ] && HIDDEN_ARGS+=(--tmpfs "$path")
done

set -x
exec bwrap \
  --ro-bind / / \
  --dev /dev \
  --proc /proc \
  --bind /tmp /tmp \
  --bind "$HOME" "$HOME" \
  "${NET_ARG}" \
  "${HIDDEN_ARGS[@]}" \
  -- "$@"

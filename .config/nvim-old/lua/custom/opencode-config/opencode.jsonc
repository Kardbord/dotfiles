{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "openrouter"
  ],
  "provider": {
    "openrouter": {
      "whitelist": [
        "openrouter/free",
        "openrouter/auto",
        "deepseek/deepseek-v4-pro",
        "deepseek/deepseek-v4-flash",
        "anthropic/claude-haiku-4.5",
        "moonshotai/kimi-k2.6",
        "qwen/qwen3.6-flash",
        "mistralai/devstral-2512",
        "google/gemini-3.5-flash",
        "google/gemma-4-31b-it:free",
        "z-ai/glm-5.1",
        "xiaomi/mimo-v2.5",
        "minimax/minimax-m2.7",
        "ibm-granite/granite-4.1-8b",
        "kwaipilot/kat-coder-pro-v2",
        "inclusionai/ring-2.6-1t",
        "inception/mercury-2"
      ],
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    }
  },
  "logLevel": "WARN",
  "autoupdate": true,
  "snapshot": true,
  "formatter": true,
  "lsp": true,
  "share": "disabled",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env*": "deny",
      "*.env.example": "allow"
    },
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "external_directory": "ask",
    "todowrite": "allow",
    "question": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "repo_clone": "ask",
    "repo_overview": "ask",
    "lsp": "allow",
    "doom_loop": "allow",
    "skill": "ask",
    "bash": {
      // Default to asking permission
      "*": "ask",
      // Allowed commands
      "grep *": "allow",
      "ls *": "allow",
      "rg *": "allow",
      "tree *": "allow",
      // Contextual commands
      "*`*`*": "ask",
      "*$(*)*": "ask",
      "$(*)": "ask",
      // Disallowed commands
      "alias *": "deny",
      "apt *": "deny",
      "apt-get *": "deny",
      "aria2c *": "deny",
      "axel *": "deny",
      "bash *": "deny",
      "chrome *": "deny",
      "command *": "deny",
      "curl *": "deny",
      "curlie *": "deny",
      "dnf *": "deny",
      "env *": "deny",
      "eval *": "deny",
      "exec *": "deny",
      "firefox *": "deny",
      "http-prompt *": "deny",
      "httpie *": "deny",
      "links *": "deny",
      "lynx *": "deny",
      "nc *": "deny",
      "pip *": "deny",
      "safari *": "deny",
      "sh *": "deny",
      "ssh *": "deny",
      "sudo *": "deny",
      "telnet *": "deny",
      "w3m *": "deny",
      "wget *": "deny",
      "xh *": "deny",
      "yum *": "deny",
      "zypper *": "deny"
    }
  }
}

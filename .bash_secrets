#!/bin/bash

# Secret management: gopass bootstrap, tool wrappers.
# Requires:
#   - gopass (https://www.gopass.pw/)
#   - age (https://github.com/FiloSottile/age)

# Tools that need secrets injected at call time.
# Format: "ENV_VAR=gopass/path [ENV_VAR2=gopass/path2 ...]"
declare -A _SECRET_TOOLS=(
  ["opencode"]="OPENROUTER_API_KEY=openrouter/api-key ANTHROPIC_API_KEY=anthropic/api-key OPENAI_API_KEY=openai/api-key"
  ["codex"]="OPENAI_API_KEY=openai/api-key"
  ["claude"]="ANTHROPIC_API_KEY=anthropic/api-key"
)

_bootstrap_gopass() {
  if ! command -v gopass &>/dev/null; then
    echo "[secrets] gopass is not installed (see https://www.gopass.pw/)" >&2
    return 1
  fi

  if ! command -v age &>/dev/null; then
    echo "[secrets] age is not installed (see https://github.com/FiloSottile/age)" >&2
    return 1
  fi

  if ! gopass list &>/dev/null 2>&1; then
    echo "[secrets] gopass store not initialized. Run: gopass setup --crypto age --remote ... --create ... (see docs/SECURITY.md)" >&2
    return 1
  fi

  return 0
}

# Retrieves secrets and injects as env vars.
_run_tool() {
  local tool="${1}"
  shift

  local -a env_args=()
  local spec="${_SECRET_TOOLS[$tool]:-}"

  if [[ -n "$spec" ]]; then
    for pair in $spec; do
      local env_var="${pair%%=*}"
      local gopass_path="${pair#*=}"
      local val
      val=$(gopass show "${gopass_path}" 2>/dev/null || echo "")
      if [[ -z "${val}" ]]; then
        echo "[secrets] Could not retrieve ${gopass_path}" >&2
        return 1
      fi
      env_args+=("${env_var}=${val}")
    done
  fi

  if ((${#env_args[@]})); then
    env "${env_args[@]}" "$tool" "$@"
  else
    command "${tool}" "$@"
  fi
}

_bootstrap_tools() {
  # Generate wrapper functions for all tools that need secrets.
  local -A _wrapped=()
  for tool in "${!_SECRET_TOOLS[@]}"; do
    [[ -n "${_wrapped[$tool]+x}" ]] && continue
    _wrapped[$tool]=1

    if command -v "$tool" &>/dev/null; then
      eval "${tool}() { _run_tool ${tool} \"\$@\"; }"
    fi
  done
}

_bootstrap_gopass && _bootstrap_tools

# Always return success so sourcing .bash_secrets never breaks shell init.
return 0

#!/bin/bash

# Secret management: passage bootstrap, tool wrappers, bwrap sandboxing.
# Requires:
#   - age (https://github.com/FiloSottile/age)
#   - passage (https://github.com/FiloSottile/passage)
# Optional:
#   - bubblewrap (https://github.com/containers/bubblewrap)

# Tools that should be bwrap-sandboxed (supply chain risk).
# The passage store and other sensitive paths are hidden via tmpfs overlays.
_SANDBOX_TOOLS=(
  "cargo"
  "claude"
  "cmake"
  "codex"
  "go"
  "make"
  "ninja"
  "npm"
  "npx"
  "opencode"
  "pip"
  "pipx"
  "task"
)

# Tools that need secrets injected at call time.
# Format: "ENV_VAR=passage/path [ENV_VAR2=passage/path2 ...]"
declare -A _SECRET_TOOLS=(
  ["opencode"]="OPENROUTER_API_KEY=openrouter/api-key ANTHROPIC_API_KEY=anthropic/api-key OPENAI_API_KEY=openai/api-key"
  ["codex"]="OPENAI_API_KEY=openai/api-key"
  ["claude"]="ANTHROPIC_API_KEY=anthropic/api-key"
)

# Resolve passage store location: respects PASSAGE_DIR, falls back to default.
_passage_store_dir() {
  printf '%s' "${PASSAGE_DIR:-$HOME/.passage}"
}

# Additional sensitive paths to hide from sandboxed tools (besides passage store).
# Each path gets overlaid with an empty tmpfs inside the sandbox.
# Only existing directories are hidden; missing ones are silently skipped.
_SANDBOX_HIDDEN_PATHS=(
  "$HOME/.ssh"
  "$HOME/.gnupg"
  "$(_passage_store_dir)"
)

_bootstrap_passage() {
  local missing=()

  command -v age &>/dev/null || missing+=("age is not installed (see https://github.com/FiloSottile/age)")
  command -v passage &>/dev/null || missing+=("passage is not installed (see https://github.com/FiloSottile/passage)")

  if ((${#missing[@]})); then
    echo "[secrets] Setup incomplete:" >&2
    for m in "${missing[@]}"; do
      echo "  - $m" >&2
    done
    return 1
  fi

  if ! passage list &>/dev/null 2>&1; then
    echo "[secrets] passage store not initialized. Run: passage init" >&2
    return 1
  fi

  return 0
}

_bootstrap_bwrap() {
  if ! command -v bwrap &>/dev/null; then
    if ((${#_SANDBOX_TOOLS[@]})); then
      echo "[secrets] bwrap not found; sandboxed tools will run unsandboxed" >&2
      echo "[secrets] Install bubblewrap: sudo zypper install bubblewrap" >&2
    fi
    return 0
  fi
  return 0
}

# Build the bwrap argument list to hide sensitive paths.
# Prints null-delimited args suitable for read -d '' consumption.
_bwrap_build_args() {
  local -a args=(
    --ro-bind / /
    --dev /dev
    --proc /proc
    --bind /tmp /tmp
    --bind "$HOME" "$HOME"
  )

  local path
  for path in "${_SANDBOX_HIDDEN_PATHS[@]}"; do
    [[ -d "$path" ]] && args+=(--tmpfs "$path")
  done

  printf '%s\0' "${args[@]}"
}

# Check whether a tool is in the sandbox list.
_should_sandbox() {
  local tool="$1"
  local t
  for t in "${_SANDBOX_TOOLS[@]}"; do
    [[ "$t" == "$tool" ]] && return 0
  done
  return 1
}

# Unified runner: retrieves secrets, injects as env vars, optionally sandboxes.
_run_tool() {
  local tool="${1}"
  shift

  local -a env_args=()
  local spec="${_SECRET_TOOLS[$tool]:-}"

  if [[ -n "$spec" ]]; then
    for pair in $spec; do
      local env_var="${pair%%=*}"
      local passage_path="${pair#*=}"
      local val
      val=$(passage show "${passage_path}" 2>/dev/null || echo "")
      if [[ -z "${val}" ]]; then
        echo "[secrets] Could not retrieve ${passage_path}" >&2
        return 1
      fi
      env_args+=("${env_var}=${val}")
    done
  fi

  if command -v bwrap &>/dev/null && _should_sandbox "$tool"; then
    # Build bwrap args dynamically (passage store + hidden paths get tmpfs overlays).
    local -a bwrap_args=()
    # TODO: Is this while loop really necessary
    while IFS= read -r -d '' arg; do
      bwrap_args+=("$arg")
    done < <(_bwrap_build_args)

    if ((${#env_args[@]})); then
      env "${env_args[@]}" bwrap "${bwrap_args[@]}" -- "$tool" "$@"
    else
      bwrap "${bwrap_args[@]}" -- "$tool" "$@"
    fi
  elif ((${#env_args[@]})); then
    env "${env_args[@]}" "$tool" "$@"
  else
    command "${tool}" "$@"
  fi
}

_sandbox_tools() {
  # Generate wrapper functions for all tools that need secrets or sandboxing.
  # Deduplicates the union of both lists.
  local -A _wrapped=()
  for tool in "${_SANDBOX_TOOLS[@]}" "${!_SECRET_TOOLS[@]}"; do
    [[ -n "${_wrapped[$tool]+x}" ]] && continue
    _wrapped[$tool]=1

    if command -v "$tool" &>/dev/null; then
      eval "${tool}() { _run_tool ${tool} \"\$@\"; }"
    fi
  done
}

_bootstrap_passage
_bootstrap_bwrap
_sandbox_tools

# Always return success so sourcing .bash_secrets never breaks shell init.
return 0
